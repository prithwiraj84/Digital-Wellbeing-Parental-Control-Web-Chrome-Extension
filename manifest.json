{
  "manifest_version": 3,
  "name": "Digital Wellbeing & Parental Control",
  "version": "1.0.0",
  "description": "A premium, performance-optimized screen time tracker and parental control dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "declarativeNetRequest",
    "alarms",
    "idle",
    "unlimitedStorage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "dashboard.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
